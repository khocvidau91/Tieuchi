<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/chat_background_gradient"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        android:elevation="0dp"
        app:contentInsetStart="0dp"
        app:contentInsetEnd="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/avatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Menu"
                app:shapeAppearanceOverlay="@style/CircleShapeAppearance"
                android:background="@null" />

            <TextView
                android:id="@+id/title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="XiaoZhi AI"
                android:textColor="#F1F5F9"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <View
                android:id="@+id/status_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/status_dot_offline" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang kết nối"
                android:textColor="#CBD5E1"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Emotion, Album, Video -->
    <FrameLayout
        android:id="@+id/emotion_container"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/emotion_face"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:scaleType="centerInside"
            android:contentDescription="Biểu cảm" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/album_art"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:visibility="gone"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_album_placeholder"
            android:background="@drawable/circle_white_border"
            android:layout_gravity="center"
            android:contentDescription="Album art" />

        <androidx.media3.ui.PlayerView
            android:id="@+id/video_player_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:use_controller="true"
            app:show_buffering="when_playing"
            app:resize_mode="fit"
            app:surface_type="texture_view" />
    </FrameLayout>

    <!-- Chat -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_recycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/emotion_container"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Activation card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/activation_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="#1E293B"
        app:cardCornerRadius="28dp"
        app:cardElevation="6dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔐 Mã kích hoạt của bạn"
                android:textColor="#F8FAFC"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/activation_pin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="------"
                android:textColor="#FBBF24"
                android:textSize="52sp"
                android:textStyle="bold"
                android:letterSpacing="0.3"
                android:layout_marginVertical="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👉 Truy cập xiaozhi.me và nhập mã"
                android:textColor="#CBD5E1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳ Đang chờ kích hoạt…"
                android:textColor="#94A3B8"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/copy_pin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Sao chép"
                android:layout_marginTop="16dp"
                android:backgroundTint="#3B82F6" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Thanh nhập liệu -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_bar_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="#1E3A5C80"
        app:cardCornerRadius="32dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:outlineProvider="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp">

            <ImageButton
                android:id="@+id/mic_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/ic_mic_circle"
                android:padding="12dp"
                android:tint="#FFFFFF"
                android:contentDescription="Microphone"
                android:layout_marginEnd="4dp" />

            <EditText
                android:id="@+id/input_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:paddingVertical="14dp"
                android:paddingHorizontal="8dp"
                android:textColor="#F1F5F9"
                android:textColorHint="#94A3B8"
                android:hint="Nhập tin nhắn..."
                android:maxLines="1"
                android:inputType="text"
                android:imeOptions="actionSend"
                android:textSize="15sp" />

            <ImageButton
                android:id="@+id/send_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/ic_send_circle"
                android:padding="12dp"
                android:tint="#FFFFFF"
                android:contentDescription="Send"
                android:layout_marginStart="4dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Menu trượt -->
    <LinearLayout
        android:id="@+id/menu_panel"
        android:layout_width="280dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="#F01E293B"
        android:elevation="16dp"
        android:translationX="-280dp"
        android:paddingTop="24dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/menu_avatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircleShapeAppearance"
            android:layout_marginBottom="12dp"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:id="@+id/menu_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="XiaoZhi AI"
            android:textColor="#F8FAFC"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:id="@+id/menu_user_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#94A3B8"
            android:textSize="13sp"
            android:layout_marginBottom="16dp"
            android:layout_gravity="center_horizontal" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="8dp" />

        <!-- Nút Cài đặt -->
        <TextView
            android:id="@+id/menu_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ Cài đặt"
            android:textColor="#CBD5E1"
            android:textSize="16sp"
            android:paddingVertical="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/menu_toggle_mcp_music"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bật/tắt MCP nhạc"
            android:textColor="#CBD5E1"
            android:textSize="16sp"
            android:paddingVertical="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/menu_toggle_mcp_video"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bật/tắt MCP video"
            android:textColor="#CBD5E1"
            android:textSize="16sp"
            android:paddingVertical="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="8dp" />

        <TextView
            android:id="@+id/menu_google_login"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đăng nhập bằng Google"
            android:textColor="#60A5FA"
            android:textSize="16sp"
            android:paddingVertical="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- PreviewView vô hình dành cho EyeManager -->
    <androidx.camera.view.PreviewView
        android:id="@+id/invisible_preview"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="invisible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>